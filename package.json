{
  "name": "C24-asset-url-cop",
  "version": "2.0.2",
  "productName": "Conversation24 File Picker",
  "description": "Get URL for file on FTP location",
  "author": "d.geus@Conversation24",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win nsis",
    "dist:portable": "electron-builder --win portable",
    "dist:mac": "electron-builder --mac dmg",
    "dist:mac:zip": "electron-builder --mac zip"
  },
  "dependencies": {
    "ssh2-sftp-client": "^11.0.0"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.conversation24.filepicker",
    "productName": "Conversation24 File Picker",
    "icon": "favicon.png",
    "asar": true,
    "compression": "maximum",
    "npmRebuild": false,
    "files": [
      "favicon.png",
      "index.html",
      "main.js",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "favicon.png",
      "signAndEditExecutable": false,
      "artifactName": "${productName}-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "mac": {
      "icon": "favicon.png",
      "identity": null,
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
